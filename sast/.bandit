### .bandit
# Исключаем проверки, которые не актуальны для данного проекта
skips: ['B101', 'B104']  # B101: assert (не используется), B104: hardcoded bind all interfaces (мы привязались к 127.0.0.1)

# Анализировать только проблемы уровня MEDIUM и выше
severity: MEDIUM

# Исключаемые пути (например, виртуальное окружение и тесты)
exclude_dirs: ['venv', 'tests']